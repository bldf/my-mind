{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@my-mind-node/core": ["packages/core/src/index.ts"],
      "@my-mind-node/react": ["packages/react/src/index.ts"],
      "@my-mind-node/importers": ["packages/importers/src/index.ts"],
      "@my-mind-node/exporters": ["packages/exporters/src/index.ts"],
      "@my-mind-node/react/styles.css": ["packages/react/src/styles.css"]
    },
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false
  }
}
