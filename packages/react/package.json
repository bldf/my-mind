{
  "name": "@my-mind-node/react",
  "version": "0.1.0-beta.3",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["./dist/styles.css"],
  "files": ["dist"],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean && cp src/styles.css dist/styles.css",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@my-mind-node/core": "workspace:*",
    "@xyflow/react": "^12.8.2",
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
