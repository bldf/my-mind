{
  "name": "my-mind-node-workspace",
  "private": true,
  "version": "0.1.0-beta.4",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --recursive --filter './packages/*' build && pnpm --filter @my-mind-node/playground build && pnpm --filter @my-mind-node/docs build",
    "test": "pnpm test:package-metadata && pnpm --recursive --filter './packages/*' test && pnpm bench",
    "test:package-metadata": "node --test tests/package-metadata.test.mjs",
    "typecheck": "pnpm --recursive --filter './packages/*' typecheck && pnpm --filter @my-mind-node/playground typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "fixtures": "node scripts/generate-fixtures.mjs",
    "bench": "node scripts/bench.mjs",
    "bundle": "node scripts/bundle-budget.mjs",
    "e2e": "playwright test",
    "docs:build": "pnpm --filter @my-mind-node/docs build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.54.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.34",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.5",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4"
  }
}
